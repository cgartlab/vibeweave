# VibeWeave Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AI Provider: 'openai', 'nvidia', or 'local'
AI_PROVIDER=openai

# OpenAI-compatible API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# NVIDIA API (OpenAI-compatible, recommended)
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# NetEase Cloud Music Open Platform
NETEASE_APP_ID=your-netease-app-id
NETEASE_APP_SECRET=your-netease-app-secret
NETEASE_PRIVATE_KEY=your-netease-private-key-pem

# Local AI (Ollama)
LOCAL_MODEL_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3
