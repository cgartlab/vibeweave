---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { motion } from 'framer-motion';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Input from '@/components/ui/form/Input/Input.astro';

// 动画变量
const containerVariants = {
  hidden: { opacity: 0 },
  visible: {
    opacity: 1,
    transition: {
      staggerChildren: 0.1
    }
  }
};

const itemVariants = {
  hidden: { y: 20, opacity: 0 },
  visible: {
    y: 0,
    opacity: 1,
    transition: {
      type: 'spring',
      stiffness: 100
    }
  }
};

// 模拟情绪数据
const emotionData = {
  labels: ['快乐', '悲伤', '愤怒', '平静', '兴奋', '紧张'],
  datasets: [
    {
      label: '情绪强度',
      data: [65, 30, 15, 70, 60, 25],
      backgroundColor: [
        'rgba(139, 92, 246, 0.2)',
        'rgba(59, 130, 246, 0.2)',
        'rgba(236, 72, 153, 0.2)',
        'rgba(16, 185, 129, 0.2)',
        'rgba(249, 115, 22, 0.2)',
        'rgba(139, 92, 246, 0.2)'
      ],
      borderColor: [
        'rgba(139, 92, 246, 1)',
        'rgba(59, 130, 246, 1)',
        'rgba(236, 72, 153, 1)',
        'rgba(16, 185, 129, 1)',
        'rgba(249, 115, 22, 1)',
        'rgba(139, 92, 246, 1)'
      ],
      borderWidth: 1
    }
  ]
};
---

<LandingLayout
  title="VibeWeave - 音乐情绪分析平台"
  description="通过AI技术分析音乐情绪，帮助你发现音乐背后的情感密码，创建更符合你心情的播放列表"
  image="/og-default.svg"
>
  <!-- 背景动效 -->
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0F0F0F] via-[#1E3A8A] to-[#4C1D95]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(139,92,246,0.15),transparent_70%)]"></div>
    <div class="absolute inset-0 overflow-hidden">
      {[...Array(12)].map((_, i) => (
        <motion.div
          key={i}
          class="absolute rounded-full bg-[rgba(139,92,246,0.05)]"
          style={{
            width: Math.random() * 300 + 100,
            height: Math.random() * 300 + 100,
            left: `${Math.random() * 100}%`,
            top: `${Math.random() * 100}%`,
          }}
          animate={{
            x: [0, Math.random() * 100 - 50],
            y: [0, Math.random() * 100 - 50],
            opacity: [0.3, 0.6, 0.3]
          }}
          transition={{
            duration: Math.random() * 20 + 10,
            repeat: Infinity,
            repeatType: 'reverse'
          }}
        />
      ))}
    </div>
  </div>

  <!-- Hero -->
  <section class="relative z-10 py-[var(--space-section-xl)] overflow-hidden">
    <div class="mx-auto max-w-6xl px-6">
      <motion.div
        variants={containerVariants}
        initial="hidden"
        animate="visible"
        class="flex flex-col items-center text-center gap-8"
      >
        <motion.div variants={itemVariants}>
          <Badge variant="brand" pill pulse class="dark:text-brand-200 text-white bg-vibe-purple/20 border-vibe-purple/40">
            AI 驱动的音乐情绪分析
          </Badge>
        </motion.div>

        <motion.h1 
          variants={itemVariants}
          class="text-4xl md:text-6xl lg:text-7xl font-bold leading-tight max-w-4xl"
        >
          <span class="bg-gradient-to-r from-vibe-purple via-vibe-blue to-vibe-pink text-transparent bg-clip-text drop-shadow-lg">
            感受音乐的 情绪脉搏
          </span>
          <br />
          <span class="text-white">VibeWeave — 音乐情绪编织师</span>
        </motion.h1>

        <motion.p 
          variants={itemVariants}
          class="text-lg md:text-xl text-gray-300 max-w-3xl"
        >
          通过先进的AI技术分析音乐情绪，帮助你发现每首歌背后的情感密码，创建更符合你心情的播放列表，让音乐与情绪完美融合。
        </motion.p>

        <motion.div 
          variants={itemVariants}
          class="w-full max-w-2xl"
        >
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-1">
              <Input 
                type="url" 
                placeholder="粘贴网易云音乐歌单链接..." 
                class="h-14 rounded-full border-gray-600 bg-black/30 backdrop-blur-sm text-white placeholder-gray-400"
              />
            </div>
            <Button 
              size="lg" 
              href="/dashboard"
              class="h-14 px-8 rounded-full bg-gradient-to-r from-vibe-purple to-vibe-blue hover:from-vibe-blue hover:to-vibe-purple transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-vibe-purple/30"
            >
              <Icon name="music" size="sm" />
              开始分析
            </Button>
          </div>
        </motion.div>

        <motion.div variants={itemVariants} class="flex gap-4">
          <Button 
            size="lg" 
            variant="outline" 
            href="#features"
            class="border-gray-600 text-white hover:border-vibe-purple hover:text-vibe-purple transition-all duration-300"
          >
            <Icon name="zap" size="sm" />
            了解更多
            <Icon name="arrow-right" size="sm" />
          </Button>
        </motion.div>
      </motion.div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="relative z-10 py-[var(--space-section-md)] bg-black/50 backdrop-blur-sm border-t border-gray-800">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-12">
      <motion.div 
        initial={{ opacity: 0, y: 20 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
        transition={{ duration: 0.6 }}
        class="flex flex-col items-center gap-4 text-center"
      >
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill class="bg-vibe-purple/20 border-vibe-purple/40 text-vibe-purple">核心功能</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white">
            探索音乐的情感世界
          </h2>
        </div>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto">
          利用AI技术，深入分析音乐的情绪特征，为你提供全新的音乐体验
        </p>
      </motion.div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {[
          {
            icon: 'heart',
            title: '音乐情绪分析',
            description: '基于AI技术，分析每首歌曲的情绪特征，包括快乐、悲伤、愤怒、平静等多种情绪维度'
          },
          {
            icon: 'layers',
            title: '多平台歌单导入',
            description: '支持从网易云音乐、QQ音乐、Spotify等平台导入歌单，一键分析所有歌曲的情绪特征'
          },
          {
            icon: 'bar-chart-3',
            title: '情绪可视化',
            description: '通过直观的图表和色彩，展示歌曲的情绪分布，让你更直观地了解音乐的情感表达'
          },
          {
            icon: 'thumbs-up',
            title: '智能歌单推荐',
            description: '根据你的情绪状态和音乐偏好，智能推荐符合你当前心情的歌曲和歌单'
          },
          {
            icon: 'tag',
            title: '情绪标签管理',
            description: '为歌曲添加自定义情绪标签，创建属于你自己的情绪音乐库，更精准地管理音乐'
          },
          {
            icon: 'refresh-cw',
            title: '多设备同步',
            description: '在不同设备间同步你的歌单和情绪分析结果，随时随地享受个性化的音乐体验'
          }
        ].map((feature, index) => (
          <motion.div
            key={index}
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5, delay: index * 0.1 }}
          >
            <Card 
              hover 
              class="h-full border-gray-800 bg-black/40 backdrop-blur-sm rounded-2xl overflow-hidden"
            >
              <div class="p-6">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-vibe-purple/20 to-vibe-blue/10 flex items-center justify-center text-vibe-purple shrink-0">
                    <Icon name={feature.icon} size="md" />
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-base font-semibold text-white mb-2">{feature.title}</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">
                      {feature.description}
                    </p>
                  </div>
                </div>
              </div>
            </Card>
          </motion.div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-black/30 backdrop-blur-sm border-t border-gray-800">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <motion.div 
          initial={{ opacity: 0, x: -20 }}
          whileInView={{ opacity: 1, x: 0 }}
          viewport={{ once: true }}
          transition={{ duration: 0.6 }}
          class="flex flex-col justify-center"
        >
          <div class="flex flex-col gap-6 mb-6">
            <Badge variant="brand" pill class="self-start bg-vibe-purple/20 border-vibe-purple/40 text-vibe-purple">如何工作</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-white">
              简单三步，
              <span class="text-vibe-purple">开启音乐情绪之旅</span>
            </h2>
          </div>
          <div class="space-y-8">
            {[
              {
                number: '01',
                title: '导入歌单',
                description: '从网易云音乐、QQ音乐或Spotify导入你的歌单，或直接上传本地音乐文件'
              },
              {
                number: '02',
                title: 'AI 情绪分析',
                description: '我们的AI算法会分析每首歌曲的情绪特征，生成详细的情绪报告'
              },
              {
                number: '03',
                title: '探索与享受',
                description: '查看情绪可视化结果，创建基于情绪的播放列表，发现音乐的情感世界'
              }
            ].map((step, index) => (
              <motion.div 
                key={index}
                initial={{ opacity: 0, y: 10 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true }}
                transition={{ duration: 0.5, delay: index * 0.1 }}
                class="relative flex gap-6"
              >
                <div class="relative">
                  <div class="w-12 h-12 rounded-full bg-gradient-to-br from-vibe-purple to-vibe-blue flex items-center justify-center text-white font-semibold shrink-0 z-10">
                    {index + 1}
                  </div>
                  {index < 2 && (
                    <div class="absolute top-12 bottom-0 left-1/2 w-0.5 bg-gradient-to-b from-vibe-purple to-transparent transform -translate-x-1/2"></div>
                  )}
                </div>
                <div>
                  <h3 class="text-xl font-semibold text-white mb-2">{step.title}</h3>
                  <p class="text-gray-400">{step.description}</p>
                </div>
                <div class="absolute -top-4 -left-12 text-6xl font-bold text-vibe-purple/10">
                  {step.number}
                </div>
              </motion.div>
            ))}
          </div>
          <Button 
            variant="primary" 
            href="/dashboard" 
            class="mt-10 self-start h-12 px-8 rounded-full bg-gradient-to-r from-vibe-purple to-vibe-blue hover:from-vibe-blue hover:to-vibe-purple transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-vibe-purple/30"
          >
            立即开始
            <Icon name="arrow-right" size="sm" />
          </Button>
        </motion.div>
        
        <motion.div 
          initial={{ opacity: 0, x: 20 }}
          whileInView={{ opacity: 1, x: 0 }}
          viewport={{ once: true }}
          transition={{ duration: 0.6, delay: 0.2 }}
        >
          <Card variant="elevated" padding="lg" class="h-full flex flex-col border-gray-800 bg-black/40 backdrop-blur-sm rounded-2xl">
            <div class="bg-black/60 rounded-2xl p-8 flex flex-col items-center justify-center text-center gap-8 h-full">
              <div class="w-24 h-24 rounded-full bg-gradient-to-br from-vibe-purple/30 to-vibe-blue/10 flex items-center justify-center text-vibe-purple">
                <Icon name="music" size="xl" />
              </div>
              <h3 class="text-2xl font-semibold text-white">支持的平台</h3>
              <div class="grid grid-cols-3 gap-8 w-full">
                <div class="flex flex-col items-center gap-3">
                  <div class="w-16 h-16 rounded-full bg-red-500/20 flex items-center justify-center text-red-400">
                    <Icon name="music" size="lg" />
                  </div>
                  <p class="text-sm text-gray-300">网易云音乐</p>
                </div>
                <div class="flex flex-col items-center gap-3">
                  <div class="w-16 h-16 rounded-full bg-green-500/20 flex items-center justify-center text-green-400">
                    <Icon name="music" size="lg" />
                  </div>
                  <p class="text-sm text-gray-300">QQ音乐</p>
                </div>
                <div class="flex flex-col items-center gap-3">
                  <div class="w-16 h-16 rounded-full bg-emerald-500/20 flex items-center justify-center text-emerald-400">
                    <Icon name="music" size="lg" />
                  </div>
                  <p class="text-sm text-gray-300">Spotify</p>
                </div>
              </div>
            </div>
          </Card>
        </motion.div>
      </div>
    </div>
  </section>

  <!-- Emotion Visualization -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-black/50 backdrop-blur-sm border-t border-gray-800">
    <div class="mx-auto max-w-6xl px-6">
      <motion.div 
        initial={{ opacity: 0, y: 20 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
        transition={{ duration: 0.6 }}
        class="flex flex-col items-center gap-8 text-center"
      >
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill class="bg-vibe-purple/20 border-vibe-purple/40 text-vibe-purple">情绪可视化</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white">
            音乐情绪图谱
          </h2>
        </div>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto">
          通过直观的图表，了解音乐的情绪分布，发现歌曲的情感特征
        </p>
        
        <motion.div 
          initial={{ opacity: 0, scale: 0.95 }}
          whileInView={{ opacity: 1, scale: 1 }}
          viewport={{ once: true }}
          transition={{ duration: 0.7 }}
          class="w-full max-w-3xl"
        >
          <Card class="border-gray-800 bg-black/40 backdrop-blur-sm rounded-2xl overflow-hidden">
            <div class="p-6">
              <div class="aspect-video bg-black/60 rounded-xl flex items-center justify-center">
                <div class="text-center">
                  <Icon name="bar-chart-3" size="4xl" class="mx-auto text-vibe-purple mb-4" />
                  <p class="text-gray-400 mb-2">情绪图谱预览</p>
                  <p class="text-sm text-gray-500">导入歌单后自动生成</p>
                </div>
              </div>
              <div class="mt-4 grid grid-cols-6 gap-2">
                {emotionData.labels.map((label, index) => (
                  <div key={index} class="flex flex-col items-center gap-1">
                    <div 
                      class="w-full h-2 rounded-full" 
                      style={{ 
                        backgroundColor: emotionData.datasets[0].backgroundColor[index],
                        width: `${emotionData.datasets[0].data[index]}%` 
                      }}
                    ></div>
                    <span class="text-xs text-gray-400">{label}</span>
                  </div>
                ))}
              </div>
            </div>
          </Card>
        </motion.div>
      </motion.div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-black/30 backdrop-blur-sm border-t border-gray-800">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-12">
      <motion.div 
        initial={{ opacity: 0, y: 20 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
        transition={{ duration: 0.6 }}
        class="flex flex-col items-center gap-4 text-center"
      >
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill class="bg-vibe-purple/20 border-vibe-purple/40 text-vibe-purple">用户反馈</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white">
            用户怎么说
          </h2>
        </div>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto">
          来自真实用户的体验分享
        </p>
      </motion.div>

      <div class="grid gap-6 md:grid-cols-2">
        {[
          {
            name: '李明',
            role: '音乐爱好者',
            quote: 'VibeWeave 让我重新认识了我的音乐库！通过情绪分析，我发现了很多以前忽略的好歌，现在我的播放列表更加符合我的心情了。',
            avatar: 'L'
          },
          {
            name: '张DJ',
            role: '专业DJ',
            quote: '作为一名DJ，VibeWeave 帮助我更好地理解音乐的情绪变化，让我能够创建更加连贯和有情感冲击力的混音。强烈推荐给所有音乐从业者！',
            avatar: 'Z'
          }
        ].map((testimonial, index) => (
          <motion.div
            key={index}
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5, delay: index * 0.1 }}
          >
            <Card 
              variant="elevated" 
              padding="lg" 
              hover 
              class="h-full border-gray-800 bg-black/40 backdrop-blur-sm rounded-2xl"
            >
              <div class="flex flex-col h-full gap-6">
                <div class="flex gap-1 text-vibe-purple" role="img" aria-label="5 out of 5 stars">
                  {[...Array(5)].map(() => (
                    <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <blockquote class="flex-1 text-gray-300 leading-relaxed">
                  "{testimonial.quote}"
                </blockquote>
                <div class="flex items-center gap-4 pt-4 border-t border-gray-800">
                  <div class="w-12 h-12 rounded-full bg-gradient-to-br from-vibe-purple to-vibe-blue flex items-center justify-center text-white font-bold text-lg shrink-0">
                    {testimonial.avatar}
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-white">{testimonial.name}</p>
                    <p class="text-xs text-gray-400">{testimonial.role}</p>
                  </div>
                </div>
              </div>
            </Card>
          </motion.div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-xl)]">
    <div class="absolute inset-0 bg-gradient-to-r from-vibe-purple/20 via-vibe-blue/20 to-vibe-pink/20"></div>
    <div class="mx-auto max-w-4xl px-6 relative z-10">
      <motion.div 
        initial={{ opacity: 0, y: 20 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
        transition={{ duration: 0.6 }}
        class="bg-black/60 backdrop-blur-sm rounded-3xl p-12 text-center border border-gray-800"
      >
        <h2 class="font-display text-3xl md:text-5xl font-bold text-white mb-6 text-balance">
          准备好探索音乐的情感世界了吗？
        </h2>
        <p class="text-lg text-gray-300 mb-10 text-balance max-w-2xl mx-auto">
          加入 VibeWeave，让AI技术帮助你发现音乐背后的情绪密码，创建更符合你心情的播放列表。
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <Button 
            size="xl" 
            href="/dashboard"
            class="h-16 px-12 rounded-full bg-gradient-to-r from-vibe-purple to-vibe-blue hover:from-vibe-blue hover:to-vibe-purple transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-vibe-purple/30 text-lg"
          >
            立即开始
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button 
            size="xl" 
            variant="outline" 
            href="/login"
            class="h-16 px-12 rounded-full border-gray-600 text-white hover:border-vibe-purple hover:text-vibe-purple transition-all duration-300 text-lg"
          >
            登录账户
          </Button>
        </div>
      </motion.div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="relative z-10 py-12 bg-black/80 backdrop-blur-sm border-t border-gray-800">
    <div class="mx-auto max-w-6xl px-6 flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="flex items-center gap-2">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-vibe-purple to-vibe-blue flex items-center justify-center text-white">
          <Icon name="music" size="sm" />
        </div>
        <span class="text-xl font-bold text-white">VibeWeave</span>
      </div>
