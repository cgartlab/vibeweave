---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="VibeWeave - 编织你的情绪歌单" description="不是推荐音乐，而是帮你编织情绪。分析歌单的情绪DNA，发现每首歌背后的氛围。">
  <div class="relative overflow-hidden">

    <!-- ============================================ -->
    <!-- HERO SECTION -->
    <!-- ============================================ -->
    <section class="hero-section relative flex min-h-[calc(100svh-4rem)] flex-col items-center justify-center px-4 py-20 text-center">
      <!-- Animated gradient orbs -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="hero-orb hero-orb-amber"></div>
        <div class="hero-orb hero-orb-purple"></div>
        <div class="hero-orb hero-orb-cyan"></div>
      </div>

      <!-- Hero content -->
      <div class="hero-content relative z-10 mx-auto max-w-4xl">
        <!-- Pill badge -->
        <div class="hero-fade mb-8 inline-flex items-center gap-2 rounded-full border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/60 px-4 py-1.5 text-sm text-[var(--vw-text-secondary)] backdrop-blur-sm" style="--delay: 0s">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-amber-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-amber-500"></span>
          </span>
          情绪驱动的音乐体验
        </div>

        <!-- Brand title -->
        <h1 class="hero-fade font-display mb-6 text-6xl font-bold leading-tight tracking-tight sm:text-7xl md:text-8xl lg:text-9xl" style="--delay: 0.15s">
          <span class="hero-title-gradient">VibeWeave</span>
        </h1>

        <!-- Tagline -->
        <p class="hero-fade mx-auto mb-12 max-w-2xl text-lg leading-relaxed text-[var(--vw-text-secondary)] sm:text-xl md:text-2xl" style="--delay: 0.3s">
          不是推荐音乐，而是帮你<span class="font-medium text-[var(--vw-text)]">编织情绪</span>
        </p>

        <!-- CTA Buttons -->
        <div class="hero-fade flex flex-col items-center justify-center gap-4 sm:flex-row" style="--delay: 0.5s">
          <a
            href="/login"
            class="cta-primary group relative inline-flex items-center gap-2 overflow-hidden rounded-xl px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-amber-500/25 transition-all duration-300 hover:shadow-xl hover:shadow-amber-500/30 hover:scale-[1.03]"
          >
            <span class="relative z-10">开始编织</span>
            <svg class="relative z-10 h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
            <div class="cta-shine absolute inset-0 bg-gradient-to-r from-amber-400 to-orange-400 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          </a>
          <a
            href="#how-it-works"
            class="cta-outline inline-flex items-center gap-2 rounded-xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/60 px-8 py-3.5 text-base font-medium text-[var(--vw-text-secondary)] backdrop-blur-sm transition-all duration-300 hover:border-amber-500/40 hover:text-[var(--vw-text)] hover:scale-[1.03]"
          >
            了解更多
            <svg class="h-4 w-4 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Bottom sound wave decoration -->
      <div class="hero-wave-container pointer-events-none absolute bottom-0 left-0 right-0" aria-hidden="true">
        <svg class="hero-wave h-24 w-full sm:h-32" viewBox="0 0 1440 128" preserveAspectRatio="none" fill="none">
          <path d="M0 80 Q30 60 60 80 T120 80 T180 80 T240 80 T300 80 T360 80 T420 80 T480 80 T540 80 T600 80 T660 80 T720 80 T780 80 T840 80 T900 80 T960 80 T1020 80 T1080 80 T1140 80 T1200 80 T1260 80 T1320 80 T1380 80 T1440 80 V128 H0 Z" fill="url(#hero-wave-grad)" opacity="0.08"/>
          <path d="M0 90 Q45 70 90 90 T180 90 T270 90 T360 90 T450 90 T540 90 T630 90 T720 90 T810 90 T900 90 T990 90 T1080 90 T1170 90 T1260 90 T1350 90 T1440 90 V128 H0 Z" fill="url(#hero-wave-grad)" opacity="0.05"/>
          <defs>
            <linearGradient id="hero-wave-grad" x1="0" y1="0" x2="1440" y2="0" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#f0a500"/>
              <stop offset="50%" stop-color="#7c5cfc"/>
              <stop offset="100%" stop-color="#00d2ff"/>
            </linearGradient>
          </defs>
        </svg>
      </div>

      <!-- Scroll indicator -->
      <div class="hero-fade absolute bottom-8 left-1/2 -translate-x-1/2 sm:bottom-12" style="--delay: 0.8s" aria-hidden="true">
        <div class="scroll-indicator flex flex-col items-center gap-2">
          <span class="text-xs tracking-widest text-[var(--vw-text-muted)] uppercase">Scroll</span>
          <div class="scroll-dot h-8 w-5 rounded-full border border-[var(--vw-text-muted)]/40 p-1">
            <div class="scroll-dot-inner h-1.5 w-1.5 rounded-full bg-amber-400"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- HOW IT WORKS SECTION -->
    <!-- ============================================ -->
    <section id="how-it-works" class="reveal-section relative px-4 py-24 sm:py-32">
      <div class="mx-auto max-w-5xl">
        <!-- Section header -->
        <div class="mb-16 text-center sm:mb-20">
          <span class="reveal-item mb-4 inline-block text-sm font-medium tracking-widest text-amber-400/80 uppercase">How it works</span>
          <h2 class="reveal-item font-display mb-4 text-3xl font-bold text-[var(--vw-text)] sm:text-4xl md:text-5xl">
            三步编织你的<span class="bg-gradient-to-r from-amber-400 to-orange-400 bg-clip-text text-transparent">情绪歌单</span>
          </h2>
          <p class="reveal-item mx-auto max-w-xl text-[var(--vw-text-secondary)]">
            从导入到编织，AI 全程理解你的音乐情绪
          </p>
        </div>

        <!-- Steps -->
        <div class="relative">
          <!-- Connection line (desktop) -->
          <div class="steps-line absolute left-0 right-0 top-1/2 hidden h-px -translate-y-1/2 lg:block" aria-hidden="true">
            <div class="h-full w-full bg-gradient-to-r from-transparent via-[var(--vw-border)] to-transparent"></div>
          </div>

          <div class="grid gap-8 sm:gap-6 lg:grid-cols-3">
            <!-- Step 1 -->
            <div class="reveal-item step-card group relative rounded-2xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/40 p-8 text-center backdrop-blur-sm transition-all duration-500 hover:border-amber-500/30 hover:shadow-lg hover:shadow-amber-500/5 hover:-translate-y-1">
              <div class="step-number mb-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-amber-500/20 to-amber-600/10 text-xl font-bold text-amber-400 transition-all duration-300 group-hover:from-amber-500/30 group-hover:to-amber-600/20 group-hover:scale-110">
                1
              </div>
              <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10 text-amber-400">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/>
                </svg>
              </div>
              <h3 class="mb-2 text-lg font-semibold text-[var(--vw-text)]">导入歌单</h3>
              <p class="text-sm leading-relaxed text-[var(--vw-text-secondary)]">
                从网易云音乐、QQ音乐或 Spotify 导入你的歌单链接
              </p>
            </div>

            <!-- Arrow (mobile) -->
            <div class="flex items-center justify-center lg:hidden" aria-hidden="true">
              <svg class="h-6 w-6 text-[var(--vw-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"/>
              </svg>
            </div>

            <!-- Step 2 -->
            <div class="reveal-item step-card group relative rounded-2xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/40 p-8 text-center backdrop-blur-sm transition-all duration-500 hover:border-purple-500/30 hover:shadow-lg hover:shadow-purple-500/5 hover:-translate-y-1" style="--reveal-delay: 0.15s">
              <div class="step-number mb-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-purple-500/20 to-purple-600/10 text-xl font-bold text-purple-400 transition-all duration-300 group-hover:from-purple-500/30 group-hover:to-purple-600/20 group-hover:scale-110">
                2
              </div>
              <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-purple-500/10 text-purple-400">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/>
                </svg>
              </div>
              <h3 class="mb-2 text-lg font-semibold text-[var(--vw-text)]">AI 情绪分析</h3>
              <p class="text-sm leading-relaxed text-[var(--vw-text-secondary)]">
                AI 解析每首歌的情绪 DNA -- 从歌词、旋律、节奏多维度理解
              </p>
            </div>

            <!-- Arrow (mobile) -->
            <div class="flex items-center justify-center lg:hidden" aria-hidden="true">
              <svg class="h-6 w-6 text-[var(--vw-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"/>
              </svg>
            </div>

            <!-- Step 3 -->
            <div class="reveal-item step-card group relative rounded-2xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/40 p-8 text-center backdrop-blur-sm transition-all duration-500 hover:border-cyan-500/30 hover:shadow-lg hover:shadow-cyan-500/5 hover:-translate-y-1" style="--reveal-delay: 0.3s">
              <div class="step-number mb-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-cyan-500/20 to-cyan-600/10 text-xl font-bold text-cyan-400 transition-all duration-300 group-hover:from-cyan-500/30 group-hover:to-cyan-600/20 group-hover:scale-110">
                3
              </div>
              <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-500/10 text-cyan-400">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/>
                </svg>
              </div>
              <h3 class="mb-2 text-lg font-semibold text-[var(--vw-text)]">编织你的情绪</h3>
              <p class="text-sm leading-relaxed text-[var(--vw-text-secondary)]">
                可视化情绪分布，重新编排歌曲顺序，让歌单成为一个故事
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- EMOTION VISUALIZATION SECTION -->
    <!-- ============================================ -->
    <section id="emotion-viz" class="reveal-section relative px-4 py-24 sm:py-32">
      <!-- Subtle background glow -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-amber-500/[0.03] blur-[120px]"></div>
      </div>

      <div class="relative mx-auto max-w-5xl">
        <!-- Section header -->
        <div class="mb-16 text-center sm:mb-20">
          <span class="reveal-item mb-4 inline-block text-sm font-medium tracking-widest text-amber-400/80 uppercase">Emotion Map</span>
          <h2 class="reveal-item font-display mb-4 text-3xl font-bold text-[var(--vw-text)] sm:text-4xl md:text-5xl">
            看见音乐的<span class="bg-gradient-to-r from-amber-400 to-orange-400 bg-clip-text text-transparent">情绪形状</span>
          </h2>
          <p class="reveal-item mx-auto max-w-xl text-[var(--vw-text-secondary)]">
            每首歌在情绪坐标系中都有自己的位置，编织就是连接这些点
          </p>
        </div>

        <!-- Emotion scatter plot -->
        <div class="reveal-item mx-auto max-w-2xl">
          <div class="emotion-chart relative rounded-2xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/40 p-6 backdrop-blur-sm sm:p-10">
            <!-- SVG Quadrant Chart -->
            <div class="relative mx-auto aspect-square max-w-md">
              <svg viewBox="0 0 400 400" class="h-full w-full" xmlns="http://www.w3.org/2000/svg">
                <!-- Grid lines -->
                <line x1="200" y1="0" x2="200" y2="400" stroke="var(--vw-border)" stroke-width="1" stroke-dasharray="4 4" opacity="0.5"/>
                <line x1="0" y1="200" x2="400" y2="200" stroke="var(--vw-border)" stroke-width="1" stroke-dasharray="4 4" opacity="0.5"/>

                <!-- Quadrant background tints -->
                <rect x="200" y="0" width="200" height="200" fill="rgba(240,165,0,0.03)" rx="0"/>
                <rect x="0" y="0" width="200" height="200" fill="rgba(124,92,252,0.03)" rx="0"/>
                <rect x="0" y="200" width="200" height="200" fill="rgba(0,210,255,0.03)" rx="0"/>
                <rect x="200" y="200" width="200" height="200" fill="rgba(239,68,68,0.03)" rx="0"/>

                <!-- Axis labels -->
                <text x="200" y="390" text-anchor="middle" fill="var(--vw-text-muted)" font-size="11" font-family="DM Sans, sans-serif">消极 ← → 积极</text>
                <text x="12" y="200" text-anchor="middle" fill="var(--vw-text-muted)" font-size="11" font-family="DM Sans, sans-serif" transform="rotate(-90, 12, 200)">低能量 ← → 高能量</text>

                <!-- Quadrant labels -->
                <text x="300" y="30" text-anchor="middle" fill="rgba(240,165,0,0.6)" font-size="13" font-weight="600" font-family="DM Sans, sans-serif">快乐 · 兴奋</text>
                <text x="100" y="30" text-anchor="middle" fill="rgba(124,92,252,0.6)" font-size="13" font-weight="600" font-family="DM Sans, sans-serif">悲伤 · 激动</text>
                <text x="100" y="385" text-anchor="middle" fill="rgba(0,210,255,0.6)" font-size="13" font-weight="600" font-family="DM Sans, sans-serif">放松 · 平静</text>
                <text x="300" y="385" text-anchor="middle" fill="rgba(239,68,68,0.5)" font-size="13" font-weight="600" font-family="DM Sans, sans-serif">消极 · 低落</text>

                <!-- Song dots - Q1: Happy/Excited (amber/orange) -->
                <circle class="song-dot" cx="280" cy="80" r="6" fill="#f0a500" opacity="0.8">
                  <animate attributeName="r" values="6;7;6" dur="3s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="320" cy="120" r="5" fill="#f59e0b" opacity="0.7">
                  <animate attributeName="r" values="5;6;5" dur="4s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="250" cy="140" r="7" fill="#f97316" opacity="0.75">
                  <animate attributeName="r" values="7;8;7" dur="3.5s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="350" cy="60" r="4" fill="#fbbf24" opacity="0.65">
                  <animate attributeName="r" values="4;5;4" dur="5s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="300" cy="160" r="5" fill="#fb923c" opacity="0.7"/>

                <!-- Song dots - Q2: Sad/Intense (purple) -->
                <circle class="song-dot" cx="80" cy="70" r="6" fill="#7c5cfc" opacity="0.75">
                  <animate attributeName="r" values="6;7;6" dur="4s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="120" cy="100" r="5" fill="#8b5cf6" opacity="0.7"/>
                <circle class="song-dot" cx="60" cy="130" r="7" fill="#a78bfa" opacity="0.65">
                  <animate attributeName="r" values="7;8;7" dur="3s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="140" cy="50" r="4" fill="#7c5cfc" opacity="0.6"/>

                <!-- Song dots - Q3: Relaxed/Calm (cyan) -->
                <circle class="song-dot" cx="70" cy="280" r="6" fill="#00d2ff" opacity="0.7">
                  <animate attributeName="r" values="6;7;6" dur="3.5s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="130" cy="310" r="5" fill="#06b6d4" opacity="0.65"/>
                <circle class="song-dot" cx="100" cy="250" r="7" fill="#22d3ee" opacity="0.7">
                  <animate attributeName="r" values="7;8;7" dur="4.5s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="50" cy="340" r="4" fill="#67e8f9" opacity="0.6"/>

                <!-- Song dots - Q4: Negative/Low (red/pink) -->
                <circle class="song-dot" cx="300" cy="300" r="5" fill="#ef4444" opacity="0.6"/>
                <circle class="song-dot" cx="340" cy="270" r="6" fill="#f87171" opacity="0.55">
                  <animate attributeName="r" values="6;7;6" dur="4s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="260" cy="330" r="4" fill="#fb7185" opacity="0.5"/>

                <!-- Center cluster (mixed emotions) -->
                <circle class="song-dot" cx="190" cy="180" r="5" fill="#f0a500" opacity="0.5"/>
                <circle class="song-dot" cx="220" cy="210" r="4" fill="#7c5cfc" opacity="0.5"/>
                <circle class="song-dot" cx="180" cy="220" r="5" fill="#00d2ff" opacity="0.5"/>
                <circle class="song-dot" cx="210" cy="190" r="6" fill="#a78bfa" opacity="0.45">
                  <animate attributeName="r" values="6;7;6" dur="5s" repeatCount="indefinite"/>
                </circle>

                <!-- Weaving path (dashed curve connecting some dots) -->
                <path d="M80 70 Q140 100 190 180 Q210 190 280 80" stroke="rgba(240,165,0,0.2)" stroke-width="1.5" fill="none" stroke-dasharray="6 4">
                  <animate attributeName="stroke-dashoffset" values="0;-20" dur="3s" repeatCount="indefinite"/>
                </path>
                <path d="M100 250 Q150 230 210 210 Q240 220 300 300" stroke="rgba(0,210,255,0.15)" stroke-width="1.5" fill="none" stroke-dasharray="6 4">
                  <animate attributeName="stroke-dashoffset" values="0;-20" dur="4s" repeatCount="indefinite"/>
                </path>
              </svg>
            </div>

            <!-- Caption -->
            <p class="mt-6 text-center text-sm text-[var(--vw-text-muted)]">
              情绪坐标系：每首歌根据 AI 分析结果落位于此，编织路径连接情绪相近的曲目
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- FINAL CTA SECTION -->
    <!-- ============================================ -->
    <section class="reveal-section relative px-4 py-24 sm:py-32">
      <div class="relative mx-auto max-w-3xl text-center">
        <!-- Background glow -->
        <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
          <div class="absolute left-1/2 top-1/2 h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-to-r from-amber-500/10 via-purple-500/5 to-cyan-500/10 blur-[100px]"></div>
        </div>

        <div class="reveal-item relative rounded-2xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/40 px-6 py-12 backdrop-blur-sm sm:px-16 sm:py-16">
          <h2 class="font-display mb-4 text-3xl font-bold text-[var(--vw-text)] sm:text-4xl md:text-5xl">
            准备好编织你的情绪了吗？
          </h2>
          <p class="reveal-item mx-auto mb-10 max-w-lg text-[var(--vw-text-secondary)]">
            导入你的歌单，让 AI 揭开每首歌的情绪密码，重新发现你音乐库中的隐藏故事
          </p>
          <a
            href="/login"
            class="cta-primary group relative inline-flex items-center gap-2 overflow-hidden rounded-xl px-10 py-4 text-lg font-semibold text-white shadow-lg shadow-amber-500/25 transition-all duration-300 hover:shadow-xl hover:shadow-amber-500/30 hover:scale-[1.03]"
          >
            <span class="relative z-10">开始使用</span>
            <svg class="relative z-10 h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
            <div class="cta-shine absolute inset-0 bg-gradient-to-r from-amber-400 to-orange-400 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ============================================= */
