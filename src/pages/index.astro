---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="VibeWeave - 编织你的情绪歌单" description="不是推荐音乐，而是帮你编织情绪。分析歌单的情绪DNA，发现每首歌背后的氛围。">
  <div class="relative overflow-hidden">

    <!-- ============================================ -->
    <!-- SECTION 1: HERO — 全屏沉浸式                  -->
    <!-- ============================================ -->
    <section class="hero-section relative flex min-h-[calc(100svh-3rem)] flex-col items-center justify-center px-6 pb-16 pt-20 text-center">
      <!-- Background radial glows -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="hero-glow-primary"></div>
        <div class="hero-glow-secondary"></div>
      </div>

      <!-- Hero content -->
      <div class="relative z-10 mx-auto max-w-4xl">
        <!-- Pill badge -->
        <div class="hero-fade mb-8 inline-flex items-center gap-2 rounded-full border border-white/[0.08] bg-white/[0.06] px-4 py-1.5 text-xs tracking-wide text-white/60" style="--delay: 0s">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#5e5ce6] opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-[#5e5ce6]"></span>
          </span>
          AI 驱动的音乐情绪分析
        </div>

        <!-- Main title -->
        <h1 class="hero-fade font-body text-[clamp(40px,8vw,88px)] font-semibold leading-[1.05] tracking-[-0.03em] text-white" style="--delay: 0.15s">
          感受音乐的<br class="sm:hidden" />
          <span class="hero-title-gradient">情绪脉搏</span>
        </h1>

        <!-- Subtitle -->
        <p class="hero-fade mx-auto mt-6 max-w-lg text-[17px] leading-relaxed text-white/50" style="--delay: 0.3s">
          不是推荐音乐，而是帮你编织情绪
        </p>

        <!-- CTA Buttons -->
        <div class="hero-fade mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row" style="--delay: 0.5s">
          <a
            href="/login"
            class="inline-flex items-center justify-center rounded-full bg-white px-7 py-3 text-[15px] font-medium text-black transition-all duration-300 hover:scale-[1.02] hover:bg-white/90 active:scale-[0.98]"
          >
            开始分析
          </a>
          <a
            href="#how-it-works"
            class="inline-flex items-center justify-center rounded-full border border-white/20 px-7 py-3 text-[15px] font-medium text-white/80 transition-all duration-300 hover:bg-white/[0.06]"
          >
            了解更多
          </a>
        </div>
      </div>

      <!-- Bottom sound wave decoration -->
      <div class="pointer-events-none absolute bottom-0 left-0 right-0" aria-hidden="true">
        <svg class="hero-wave h-16 w-full sm:h-24" viewBox="0 0 1440 96" preserveAspectRatio="none" fill="none">
          <path d="M0 48 Q20 38 40 48 T80 48 T120 48 T160 48 T200 48 T240 48 T280 48 T320 48 T360 48 T400 48 T440 48 T480 48 T520 48 T560 48 T600 48 T640 48 T680 48 T720 48 T760 48 T800 48 T840 48 T880 48 T920 48 T960 48 T1000 48 T1040 48 T1080 48 T1120 48 T1160 48 T1200 48 T1240 48 T1280 48 T1320 48 T1360 48 T1400 48 T1440 48 V96 H0 Z" fill="url(#hero-wave-grad-new)" opacity="0.06"/>
          <path d="M0 56 Q30 44 60 56 T120 56 T180 56 T240 56 T300 56 T360 56 T420 56 T480 56 T540 56 T600 56 T660 56 T720 56 T780 56 T840 56 T900 56 T960 56 T1020 56 T1080 56 T1140 56 T1200 56 T1260 56 T1320 56 T1380 56 T1440 56 V96 H0 Z" fill="url(#hero-wave-grad-new)" opacity="0.04"/>
          <defs>
            <linearGradient id="hero-wave-grad-new" x1="0" y1="0" x2="1440" y2="0" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#5e5ce6"/>
              <stop offset="50%" stop-color="#bf5af2"/>
              <stop offset="100%" stop-color="#ff375f"/>
            </linearGradient>
          </defs>
        </svg>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SECTION 2: HOW IT WORKS — 三步流程            -->
    <!-- ============================================ -->
    <section id="how-it-works" class="relative px-6 py-24 sm:py-32">
      <div class="mx-auto max-w-5xl">
        <!-- Section header -->
        <div class="mb-16 text-center sm:mb-20">
          <h2 class="reveal-item text-[clamp(28px,4vw,48px)] font-semibold tracking-tight text-white">
            三步开始
          </h2>
          <p class="reveal-item mt-3 text-[15px] text-white/40" style="--reveal-delay: 0.1s">
            导入歌单，AI 自动分析情绪 DNA
          </p>
        </div>

        <!-- Steps grid -->
        <div class="grid gap-4 lg:grid-cols-3">
          <!-- Step 1 -->
          <div class="reveal-item step-card rounded-2xl border border-white/[0.06] bg-white/[0.04] p-8 transition-all duration-500 hover:bg-white/[0.06]" style="--reveal-delay: 0s">
            <div class="text-6xl font-bold text-white/[0.06]">01</div>
            <h3 class="mt-4 text-lg font-semibold text-white">导入歌单</h3>
            <p class="mt-2 text-[15px] leading-relaxed text-white/40">
              粘贴网易云歌单链接，一键导入全部歌曲
            </p>
          </div>

          <!-- Step 2 -->
          <div class="reveal-item step-card rounded-2xl border border-white/[0.06] bg-white/[0.04] p-8 transition-all duration-500 hover:bg-white/[0.06]" style="--reveal-delay: 0.15s">
            <div class="text-6xl font-bold text-white/[0.06]">02</div>
            <h3 class="mt-4 text-lg font-semibold text-white">AI 分析</h3>
            <p class="mt-2 text-[15px] leading-relaxed text-white/40">
              基于歌词和音频特征，深度解析每首歌的情绪 DNA
            </p>
          </div>

          <!-- Step 3 -->
          <div class="reveal-item step-card rounded-2xl border border-white/[0.06] bg-white/[0.04] p-8 transition-all duration-500 hover:bg-white/[0.06]" style="--reveal-delay: 0.3s">
            <div class="text-6xl font-bold text-white/[0.06]">03</div>
            <h3 class="mt-4 text-lg font-semibold text-white">情绪编织</h3>
            <p class="mt-2 text-[15px] leading-relaxed text-white/40">
              可视化情绪分布，AI 智能编排完美播放顺序
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SECTION 3: EMOTION VISUALIZATION              -->
    <!-- ============================================ -->
    <section id="emotion-viz" class="relative bg-black px-6 py-24 sm:py-32">
      <div class="mx-auto max-w-5xl">
        <!-- Section header -->
        <div class="mb-16 text-center sm:mb-20">
          <h2 class="reveal-item text-[clamp(28px,4vw,48px)] font-semibold tracking-tight text-white">
            看见你的 <span class="emotion-title-gradient">情绪图谱</span>
          </h2>
          <p class="reveal-item mt-3 text-[15px] text-white/40" style="--reveal-delay: 0.1s">
            七维情绪模型，精准映射每首歌的情感坐标
          </p>
        </div>

        <!-- Emotion scatter plot -->
        <div class="reveal-item mx-auto max-w-3xl" style="--reveal-delay: 0.15s">
          <div class="emotion-chart relative rounded-2xl border border-white/[0.06] bg-white/[0.03] p-6 sm:p-10">
            <!-- SVG Quadrant Chart -->
            <div class="relative mx-auto aspect-square max-w-md">
              <svg viewBox="0 0 400 400" class="h-full w-full" xmlns="http://www.w3.org/2000/svg">
                <!-- Quadrant background tints -->
                <defs>
                  <radialGradient id="q1-glow" cx="75%" cy="25%" r="50%">
                    <stop offset="0%" stop-color="rgba(240,165,0,0.06)"/>
                    <stop offset="100%" stop-color="transparent"/>
                  </radialGradient>
                  <radialGradient id="q2-glow" cx="25%" cy="25%" r="50%">
                    <stop offset="0%" stop-color="rgba(94,92,230,0.06)"/>
                    <stop offset="100%" stop-color="transparent"/>
                  </radialGradient>
                  <radialGradient id="q3-glow" cx="25%" cy="75%" r="50%">
                    <stop offset="0%" stop-color="rgba(0,210,255,0.06)"/>
                    <stop offset="100%" stop-color="transparent"/>
                  </radialGradient>
                  <radialGradient id="q4-glow" cx="75%" cy="75%" r="50%">
                    <stop offset="0%" stop-color="rgba(255,55,95,0.06)"/>
                    <stop offset="100%" stop-color="transparent"/>
                  </radialGradient>
                </defs>

                <rect x="200" y="0" width="200" height="200" fill="url(#q1-glow)"/>
                <rect x="0" y="0" width="200" height="200" fill="url(#q2-glow)"/>
                <rect x="0" y="200" width="200" height="200" fill="url(#q3-glow)"/>
                <rect x="200" y="200" width="200" height="200" fill="url(#q4-glow)"/>

                <!-- Grid lines -->
                <line x1="200" y1="0" x2="200" y2="400" stroke="rgba(255,255,255,0.08)" stroke-width="1" stroke-dasharray="4 4"/>
                <line x1="0" y1="200" x2="400" y2="200" stroke="rgba(255,255,255,0.08)" stroke-width="1" stroke-dasharray="4 4"/>

                <!-- Axis labels -->
                <text x="200" y="390" text-anchor="middle" fill="rgba(255,255,255,0.25)" font-size="11" font-family="DM Sans, sans-serif">消极 &larr; &rarr; 积极</text>
                <text x="12" y="200" text-anchor="middle" fill="rgba(255,255,255,0.25)" font-size="11" font-family="DM Sans, sans-serif" transform="rotate(-90, 12, 200)">低能量 &larr; &rarr; 高能量</text>

                <!-- Quadrant labels -->
                <text x="300" y="30" text-anchor="middle" fill="rgba(240,165,0,0.4)" font-size="12" font-weight="500" font-family="DM Sans, sans-serif">快乐 · 兴奋</text>
                <text x="100" y="30" text-anchor="middle" fill="rgba(94,92,230,0.4)" font-size="12" font-weight="500" font-family="DM Sans, sans-serif">悲伤 · 激动</text>
                <text x="100" y="385" text-anchor="middle" fill="rgba(0,210,255,0.4)" font-size="12" font-weight="500" font-family="DM Sans, sans-serif">放松 · 平静</text>
                <text x="300" y="385" text-anchor="middle" fill="rgba(255,55,95,0.35)" font-size="12" font-weight="500" font-family="DM Sans, sans-serif">紧张 · 低落</text>

                <!-- Song dots — Q1: Happy/Excited -->
                <circle class="song-dot" cx="280" cy="80" r="7" fill="#f0a500" opacity="0.75">
                  <animate attributeName="r" values="7;8.5;7" dur="3s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="330" cy="130" r="5" fill="#fbbf24" opacity="0.65">
                  <animate attributeName="r" values="5;6;5" dur="4.2s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="250" cy="140" r="8" fill="#f97316" opacity="0.7">
                  <animate attributeName="r" values="8;9.5;8" dur="3.5s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="355" cy="60" r="4.5" fill="#fbbf24" opacity="0.6">
                  <animate attributeName="r" values="4.5;5.5;4.5" dur="5s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="310" cy="170" r="5.5" fill="#fb923c" opacity="0.65"/>

                <!-- Song dots — Q2: Sad/Intense -->
                <circle class="song-dot" cx="80" cy="70" r="6.5" fill="#5e5ce6" opacity="0.7">
                  <animate attributeName="r" values="6.5;7.5;6.5" dur="4s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="120" cy="110" r="5" fill="#8b5cf6" opacity="0.6"/>
                <circle class="song-dot" cx="55" cy="140" r="7" fill="#a78bfa" opacity="0.6">
                  <animate attributeName="r" values="7;8;7" dur="3.2s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="145" cy="55" r="4" fill="#7c5cfc" opacity="0.55"/>

                <!-- Song dots — Q3: Relaxed/Calm -->
                <circle class="song-dot" cx="70" cy="280" r="6" fill="#00d2ff" opacity="0.65">
                  <animate attributeName="r" values="6;7;6" dur="3.8s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="130" cy="310" r="5" fill="#06b6d4" opacity="0.6"/>
                <circle class="song-dot" cx="95" cy="250" r="7.5" fill="#22d3ee" opacity="0.65">
                  <animate attributeName="r" values="7.5;8.5;7.5" dur="4.5s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="50" cy="340" r="4" fill="#67e8f9" opacity="0.5"/>

                <!-- Song dots — Q4: Tense/Low -->
                <circle class="song-dot" cx="310" cy="300" r="5.5" fill="#ff375f" opacity="0.55">
                  <animate attributeName="r" values="5.5;6.5;5.5" dur="4s" repeatCount="indefinite"/>
                </circle>
                <circle class="song-dot" cx="345" cy="270" r="6" fill="#f87171" opacity="0.5"/>
                <circle class="song-dot" cx="265" cy="335" r="4.5" fill="#fb7185" opacity="0.45"/>

                <!-- Center cluster (mixed emotions) -->
                <circle class="song-dot" cx="185" cy="185" r="5" fill="#f0a500" opacity="0.4"/>
                <circle class="song-dot" cx="220" cy="215" r="4" fill="#5e5ce6" opacity="0.4"/>
                <circle class="song-dot" cx="175" cy="225" r="5" fill="#00d2ff" opacity="0.4"/>
                <circle class="song-dot" cx="215" cy="185" r="6" fill="#a78bfa" opacity="0.35">
                  <animate attributeName="r" values="6;7;6" dur="5s" repeatCount="indefinite"/>
                </circle>

                <!-- Weaving paths -->
                <path d="M80 70 Q140 100 185 185 Q215 185 280 80" stroke="rgba(94,92,230,0.15)" stroke-width="1.5" fill="none" stroke-dasharray="6 4">
                  <animate attributeName="stroke-dashoffset" values="0;-20" dur="3s" repeatCount="indefinite"/>
                </path>
                <path d="M95 250 Q150 230 215 215 Q245 225 310 300" stroke="rgba(0,210,255,0.12)" stroke-width="1.5" fill="none" stroke-dasharray="6 4">
                  <animate attributeName="stroke-dashoffset" values="0;-20" dur="4s" repeatCount="indefinite"/>
                </path>
              </svg>
            </div>

            <!-- Emotion tags -->
            <div class="mt-8 flex flex-wrap items-center justify-center gap-2">
              <span class="rounded-full bg-[#f0a500]/10 px-3 py-1 text-xs text-[#f0a500]/80">快乐</span>
              <span class="rounded-full bg-[#5e5ce6]/10 px-3 py-1 text-xs text-[#5e5ce6]/80">悲伤</span>
              <span class="rounded-full bg-[#00d2ff]/10 px-3 py-1 text-xs text-[#00d2ff]/80">放松</span>
              <span class="rounded-full bg-[#f97316]/10 px-3 py-1 text-xs text-[#f97316]/80">兴奋</span>
              <span class="rounded-full bg-[#22d3ee]/10 px-3 py-1 text-xs text-[#22d3ee]/80">宁静</span>
              <span class="rounded-full bg-[#ff375f]/10 px-3 py-1 text-xs text-[#ff375f]/80">紧张</span>
              <span class="rounded-full bg-[#a78bfa]/10 px-3 py-1 text-xs text-[#a78bfa]/80">怀旧</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SECTION 4: FINAL CTA — 行动召唤               -->
    <!-- ============================================ -->
    <section class="relative px-6 py-24 sm:py-32">
      <div class="relative mx-auto max-w-3xl text-center">
        <!-- Background glow -->
        <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
          <div class="absolute left-1/2 top-1/2 h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#5e5ce6]/[0.06] blur-[120px]"></div>
        </div>

        <h2 class="reveal-item text-[clamp(32px,5vw,56px)] font-semibold tracking-tight text-white">
          准备好了吗？
        </h2>
        <p class="reveal-item mt-4 text-[15px] text-white/40" style="--reveal-delay: 0.1s">
          让 AI 为你编织完美的情绪体验
        </p>
        <div class="reveal-item mt-10" style="--reveal-delay: 0.2s">
          <a
            href="/login"
            class="inline-flex items-center justify-center rounded-full bg-white px-7 py-3 text-[15px] font-medium text-black transition-all duration-300 hover:scale-[1.02] hover:bg-white/90 active:scale-[0.98]"
          >
            立即开始
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ============================================= */
  /* HERO — Background Glows                       */
  /* ============================================= */

  .hero-glow-primary {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(94, 92, 230, 0.15), transparent 70%);
    pointer-events: none;
  }

  .hero-glow-secondary {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 50% 40% at 80% 80%, rgba(240, 165, 0, 0.08), transparent 60%);
    pointer-events: none;
  }

  /* ============================================= */
  /* HERO — Title Gradient                         */
  /* ============================================= */

  .hero-title-gradient {
    background: linear-gradient(135deg, #5e5ce6 0%, #bf5af2 50%, #ff375f 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ============================================= */
  /* HERO — Fade-in Animation (Apple easing)       */
  /* ============================================= */

  .hero-fade {
    opacity: 0;
    transform: translateY(24px);
    animation: fadeInUp 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(24px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ============================================= */
  /* HERO — Wave Subtle Breathe                    */
  /* ============================================= */

  .hero-wave {
    animation: waveBreathe 6s ease-in-out infinite;
  }

  @keyframes waveBreathe {
    0%, 100% { transform: scaleY(1); transform-origin: bottom; }
    50% { transform: scaleY(1.12); transform-origin: bottom; }
  }

  /* ============================================= */
  /* EMOTION — Title Gradient                      */
  /* ============================================= */

  .emotion-title-gradient {
    background: linear-gradient(135deg, #5e5ce6 0%, #bf5af2 50%, #ff375f 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ============================================= */
  /* REVEAL ON SCROLL                              */
  /* ============================================= */

  .reveal-item {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transition-delay: var(--reveal-delay, 0s);
  }

  .reveal-item.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .step-card {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                background-color 0.5s ease;
    transition-delay: var(--reveal-delay, 0s);
  }

  .step-card.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* ============================================= */
  /* EMOTION CHART                                 */
  /* ============================================= */

  .song-dot {
    transition: r 0.3s ease;
  }

  .emotion-chart {
    transition: border-color 0.5s ease, box-shadow 0.5s ease;
  }

  .emotion-chart:hover {
    border-color: rgba(94, 92, 230, 0.15);
    box-shadow: 0 0 60px rgba(94, 92, 230, 0.04);
  }
</style>

<script>
  // IntersectionObserver for scroll-triggered reveal animations
  document.addEventListener('DOMContentLoaded', () => {
    const revealItems = document.querySelectorAll('.reveal-item, .step-card');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.15,
        rootMargin: '0px 0px -40px 0px',
      }
    );

    revealItems.forEach((item) => observer.observe(item));
  });
</script>