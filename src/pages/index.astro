  }

  /* Hero title gradient */
  .hero-title-gradient {
    background: linear-gradient(135deg, #f0a500 0%, #f97316 40%, #fbbf24 70%, #f0a500 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
