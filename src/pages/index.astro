---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="VibeWeave - 编织你的情绪歌单" description="不是推荐音乐，而是帮你编织情绪。分析歌单的情绪DNA，发现每首歌背后的氛围。">
  <main class="relative overflow-hidden">
    <!-- Animated gradient mesh background -->
    <div class="animate-gradient pointer-events-none absolute inset-0 -z-10 opacity-40">
      <div class="gradient-orb gradient-orb-1"></div>
      <div class="gradient-orb gradient-orb-2"></div>
      <div class="gradient-orb gradient-orb-3"></div>
    </div>

    <!-- Floating decorative music notes -->
    <div class="pointer-events-none absolute inset-0 -z-5 overflow-hidden" aria-hidden="true">
      <svg class="floating-note floating-note-1 absolute left-[10%] top-[15%] h-8 w-8 text-amber-500/20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55C7.79 13 6 14.79 6 17s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
      </svg>
      <svg class="floating-note floating-note-2 absolute right-[15%] top-[25%] h-6 w-6 text-purple-500/20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55C7.79 13 6 14.79 6 17s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
      </svg>
      <svg class="floating-note floating-note-3 absolute left-[20%] top-[60%] h-10 w-10 text-cyan-500/15" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55C7.79 13 6 14.79 6 17s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
      </svg>
      <svg class="floating-note floating-note-4 absolute right-[10%] top-[70%] h-7 w-7 text-amber-400/15" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55C7.79 13 6 14.79 6 17s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
      </svg>
      <svg class="floating-note floating-note-5 absolute left-[50%] top-[10%] h-5 w-5 text-orange-500/15" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55C7.79 13 6 14.79 6 17s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
      </svg>
    </div>

    <!-- Floating waveform SVG -->
    <div class="pointer-events-none absolute bottom-0 left-0 right-0 -z-5 opacity-10" aria-hidden="true">
      <svg class="animate-waveform h-32 w-full" viewBox="0 0 1440 128" preserveAspectRatio="none" fill="none">
        <path d="M0 64 Q60 20 120 64 T240 64 T360 64 T480 64 T600 64 T720 64 T840 64 T960 64 T1080 64 T1200 64 T1320 64 T1440 64 V128 H0 Z" fill="url(#waveform-gradient)"/>
        <defs>
          <linearGradient id="waveform-gradient" x1="0" y1="0" x2="1440" y2="0" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#7c5cfc"/>
            <stop offset="50%" stop-color="#f0a500"/>
            <stop offset="100%" stop-color="#00d2ff"/>
          </linearGradient>
        </defs>
      </svg>
    </div>

    <!-- Hero Section -->
    <section class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-4 py-20 text-center">
      <div class="animate-fade-in-up mx-auto max-w-4xl">
        <!-- Logo mark -->
        <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/60 px-4 py-1.5 text-sm text-[var(--vw-text-secondary)] backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-amber-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-amber-500"></span>
          </span>
          情绪驱动的音乐体验
        </div>

        <!-- Main heading -->
        <h1 class="font-display mb-6 text-5xl font-bold leading-tight tracking-tight sm:text-6xl md:text-7xl lg:text-8xl">
          <span class="bg-gradient-to-r from-amber-400 via-orange-400 to-amber-500 bg-clip-text text-transparent">
            VibeWeave
          </span>
        </h1>

        <!-- Tagline -->
        <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-[var(--vw-text-secondary)] sm:text-xl">
          不是推荐音乐，而是帮你<span class="font-medium text-[var(--vw-text)]">编织情绪</span>
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/login"
            class="group relative inline-flex items-center gap-2 overflow-hidden rounded-xl bg-gradient-to-r from-amber-500 to-orange-500 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-amber-500/25 transition-all duration-300 hover:shadow-xl hover:shadow-amber-500/30"
          >
            <span class="relative z-10">开始编织</span>
            <svg class="relative z-10 h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
            <div class="absolute inset-0 bg-gradient-to-r from-amber-400 to-orange-400 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          </a>
          <a
            href="#features"
            class="inline-flex items-center gap-2 rounded-xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/60 px-8 py-3.5 text-base font-medium text-[var(--vw-text-secondary)] backdrop-blur-sm transition-all duration-300 hover:border-[var(--vw-accent)]/40 hover:text-[var(--vw-text)]"
          >
            了解更多
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </a>
        </div>

        <!-- Stats row -->
        <div class="mt-16 flex items-center justify-center gap-8 text-center sm:gap-12">
          <div>
            <div class="text-2xl font-bold text-[var(--vw-text)] sm:text-3xl">3</div>
            <div class="mt-1 text-xs text-[var(--vw-text-muted)] sm:text-sm">支持平台</div>
          </div>
          <div class="h-8 w-px bg-[var(--vw-border)]"></div>
          <div>
            <div class="text-2xl font-bold text-[var(--vw-text)] sm:text-3xl">AI</div>
            <div class="mt-1 text-xs text-[var(--vw-text-muted)] sm:text-sm">情绪分析</div>
          </div>
          <div class="h-8 w-px bg-[var(--vw-border)]"></div>
          <div>
            <div class="text-2xl font-bold text-[var(--vw-text)] sm:text-3xl">&infin;</div>
            <div class="mt-1 text-xs text-[var(--vw-text-muted)] sm:text-sm">编织可能</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="relative px-4 py-24">
      <div class="mx-auto max-w-6xl">
        <div class="mb-16 text-center">
          <h2 class="font-display mb-4 text-3xl font-bold text-[var(--vw-text)] sm:text-4xl">
            用情绪重新定义<span class="bg-gradient-to-r from-amber-400 to-orange-400 bg-clip-text text-transparent">歌单</span>
          </h2>
          <p class="mx-auto max-w-xl text-[var(--vw-text-secondary)]">
            每首歌都承载着独特的情感频率，VibeWeave 帮你捕捉、理解、编织
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <!-- Feature 1: Emotion Analysis -->
          <div class="group rounded-xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/60 p-6 backdrop-blur-sm transition-all duration-300 hover:border-purple-500/30 hover:shadow-lg hover:shadow-purple-500/5 hover:-translate-y-1">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-purple-500/10 text-purple-400 transition-colors duration-300 group-hover:bg-purple-500/20">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/>
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-[var(--vw-text)]">情绪分析</h3>
            <p class="text-sm leading-relaxed text-[var(--vw-text-secondary)]">
              AI 深度解析每首歌的情绪DNA，从歌词、旋律、节奏多维度理解音乐情感
            </p>
          </div>

          <!-- Feature 2: Smart Sorting -->
          <div class="group rounded-xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/60 p-6 backdrop-blur-sm transition-all duration-300 hover:border-amber-500/30 hover:shadow-lg hover:shadow-amber-500/5 hover:-translate-y-1">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-amber-500/10 text-amber-400 transition-colors duration-300 group-hover:bg-amber-500/20">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5m13.5-6L16.5 15m0 0L12 10.5m4.5 4.5V3"/>
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-[var(--vw-text)]">智能排序</h3>
            <p class="text-sm leading-relaxed text-[var(--vw-text-secondary)]">
              基于情绪流动自动编排歌曲顺序，让歌单成为一个完整的故事线
            </p>
          </div>

          <!-- Feature 3: Natural Language -->
          <div class="group rounded-xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/60 p-6 backdrop-blur-sm transition-all duration-300 hover:border-cyan-500/30 hover:shadow-lg hover:shadow-cyan-500/5 hover:-translate-y-1">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-cyan-500/10 text-cyan-400 transition-colors duration-300 group-hover:bg-cyan-500/20">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-[var(--vw-text)]">自然语言控制</h3>
            <p class="text-sm leading-relaxed text-[var(--vw-text-secondary)]">
              用日常语言描述你想要的氛围，AI 自动挑选并排列最契合的歌曲
            </p>
          </div>

          <!-- Feature 4: Cross Platform -->
          <div class="group rounded-xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/60 p-6 backdrop-blur-sm transition-all duration-300 hover:border-emerald-500/30 hover:shadow-lg hover:shadow-emerald-500/5 hover:-translate-y-1">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400 transition-colors duration-300 group-hover:bg-emerald-500/20">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-[var(--vw-text)]">跨平台支持</h3>
            <p class="text-sm leading-relaxed text-[var(--vw-text-secondary)]">
              支持网易云音乐、QQ音乐、Spotify，一个工具管理所有平台的歌单
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="relative px-4 py-24">
      <div class="mx-auto max-w-3xl text-center">
        <div class="relative rounded-2xl border border-[var(--vw-border)] bg-[var(--vw-bg-card)]/40 p-12 backdrop-blur-sm sm:p-16">
          <!-- Glow effect behind card -->
          <div class="absolute inset-0 -z-10 rounded-2xl bg-gradient-to-r from-amber-500/10 via-purple-500/10 to-cyan-500/10 blur-2xl"></div>

          <h2 class="font-display mb-4 text-3xl font-bold text-[var(--vw-text)] sm:text-4xl">
            准备好编织你的情绪了吗？
          </h2>
          <p class="mx-auto mb-8 max-w-lg text-[var(--vw-text-secondary)]">
            导入你的歌单，让 AI 揭开每首歌的情绪密码，重新发现你音乐库中的隐藏故事
          </p>
          <a
            href="/login"
            class="group relative inline-flex items-center gap-2 overflow-hidden rounded-xl bg-gradient-to-r from-amber-500 to-orange-500 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-amber-500/25 transition-all duration-300 hover:shadow-xl hover:shadow-amber-500/30"
          >
            <span class="relative z-10">开始编织</span>
            <svg class="relative z-10 h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
            <div class="absolute inset-0 bg-gradient-to-r from-amber-400 to-orange-400 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Gradient mesh animation */
  .animate-gradient {
    position: relative;
  }

  .gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    animation: gradient-float 20s ease-in-out infinite;
  }

  .gradient-orb-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(124, 92, 252, 0.3) 0%, transparent 70%);
    top: -10%;
    left: -10%;
    animation-delay: 0s;
  }

  .gradient-orb-2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(240, 165, 0, 0.25) 0%, transparent 70%);
    top: 30%;
    right: -10%;
    animation-delay: -7s;
    animation-duration: 25s;
  }

  .gradient-orb-3 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(0, 210, 255, 0.2) 0%, transparent 70%);
    bottom: -5%;
    left: 30%;
    animation-delay: -14s;
    animation-duration: 22s;
  }

  @keyframes gradient-float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(60px, -40px) scale(1.1);
    }
    50% {
      transform: translate(-30px, 60px) scale(0.95);
    }
    75% {
      transform: translate(40px, 30px) scale(1.05);
    }
  }

  /* Floating music notes */
  .floating-note {
    animation: note-float 15s ease-in-out infinite;
  }

  .floating-note-1 {
    animation-duration: 18s;
    animation-delay: 0s;
  }

  .floating-note-2 {
    animation-duration: 22s;
    animation-delay: -4s;
  }

  .floating-note-3 {
    animation-duration: 20s;
    animation-delay: -8s;
  }

  .floating-note-4 {
    animation-duration: 16s;
    animation-delay: -12s;
  }

  .floating-note-5 {
    animation-duration: 24s;
    animation-delay: -6s;
  }

  @keyframes note-float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
      opacity: 0.6;
    }
    25% {
      transform: translateY(-30px) rotate(10deg);
      opacity: 1;
    }
    50% {
      transform: translateY(-15px) rotate(-5deg);
      opacity: 0.8;
    }
    75% {
      transform: translateY(-40px) rotate(8deg);
      opacity: 0.5;
    }
  }

  /* Waveform animation */
  .animate-waveform {
    animation: waveform-pulse 8s ease-in-out infinite;
  }

  @keyframes waveform-pulse {
    0%, 100% {
      transform: scaleY(1);
      transform-origin: bottom;
    }
    50% {
      transform: scaleY(1.3);
      transform-origin: bottom;
    }
  }

  /* Fade in up animation */
  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
