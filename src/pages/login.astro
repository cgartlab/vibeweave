---
import '../styles/global.css';
import LoginForm from '../components/auth/LoginForm';
import RegisterForm from '../components/auth/RegisterForm';
import OAuthButtons from '../components/auth/OAuthButtons';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="登录或注册 VibeWeave — AI 驱动的音乐情绪分析" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Playfair+Display:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>登录 - VibeWeave</title>
  </head>
  <body class="min-h-screen bg-black">
    <div class="relative min-h-[calc(100vh-3rem)] flex items-center justify-center">
      <!-- Subtle radial glow -->
      <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
        <div class="h-[600px] w-[600px] rounded-full bg-[radial-gradient(circle_at_center,rgba(94,92,230,0.08)_0%,transparent_70%)]"></div>
      </div>

      <!-- Content -->
      <div class="relative w-full max-w-sm px-6">
        <!-- Brand -->
        <div class="mb-10 text-center">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-[#5e5ce6] to-[#bf5af2]">
            <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
            </svg>
          </div>
          <h1 class="font-body mt-4 text-2xl font-semibold text-white">VibeWeave</h1>
          <p class="mt-1 text-sm text-white/40">AI 驱动的音乐情绪分析</p>
        </div>

        <!-- Tab Switcher -->
        <div class="mb-8 flex rounded-full bg-white/[0.06] p-1" id="auth-tabs" role="tablist">
          <button
            id="tab-login"
            role="tab"
            aria-selected="true"
            data-tab="login"
            class="rounded-full bg-white px-4 py-2 text-sm font-medium text-black transition-all duration-300"
          >
            登录
          </button>
          <button
            id="tab-register"
            role="tab"
            aria-selected="false"
            data-tab="register"
            class="rounded-full px-4 py-2 text-sm font-medium text-white/50 transition-all duration-300 hover:text-white/70"
          >
            注册
          </button>
        </div>

        <!-- Login Form -->
        <div id="panel-login" role="tabpanel">
          <LoginForm client:load />
        </div>

        <!-- Register Form -->
        <div id="panel-register" role="tabpanel" class="hidden">
          <RegisterForm client:load />
        </div>

        <!-- Divider -->
        <div class="my-6 flex items-center gap-4">
          <div class="h-px flex-1 border-white/[0.08]"></div>
          <span class="text-xs text-white/30">或</span>
          <div class="h-px flex-1 border-white/[0.08]"></div>
        </div>

        <!-- OAuth Buttons -->
        <OAuthButtons client:load />

        <!-- Bottom Links -->
        <div class="mt-10 text-center">
          <p class="text-xs text-white/20">
            继续即表示您同意我们的
            <a href="/terms" class="transition-colors hover:text-white/40">服务条款</a>
            和
            <a href="/privacy" class="transition-colors hover:text-white/40">隐私政策</a>
          </p>
        </div>
      </div>
    </div>
  </body>
</html>

<script>
  function initAuthTabs() {
    const tabLogin = document.getElementById('tab-login');
    const tabRegister = document.getElementById('tab-register');
    const panelLogin = document.getElementById('panel-login');
    const panelRegister = document.getElementById('panel-register');

    if (!tabLogin || !tabRegister || !panelLogin || !panelRegister) return;

    const activeTabClasses = 'rounded-full bg-white px-4 py-2 text-sm font-medium text-black transition-all duration-300';
    const inactiveTabClasses = 'rounded-full px-4 py-2 text-sm font-medium text-white/50 transition-all duration-300 hover:text-white/70';

    // Check URL params for initial tab
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('tab') === 'register') {
      switchToRegister();
    }

    tabLogin?.addEventListener('click', switchToLogin);
    tabRegister?.addEventListener('click', switchToRegister);

    function switchToLogin() {
      tabLogin.className = activeTabClasses;
      tabLogin.setAttribute('aria-selected', 'true');
      tabRegister.className = inactiveTabClasses;
      tabRegister.setAttribute('aria-selected', 'false');
      panelLogin.classList.remove('hidden');
      panelRegister.classList.add('hidden');
      // Update URL without reload
      const url = new URL(window.location);
      url.searchParams.delete('tab');
      window.history.replaceState({}, '', url);
    }

    function switchToRegister() {
      tabRegister.className = activeTabClasses;
      tabRegister.setAttribute('aria-selected', 'true');
      tabLogin.className = inactiveTabClasses;
      tabLogin.setAttribute('aria-selected', 'false');
      panelRegister.classList.remove('hidden');
      panelLogin.classList.add('hidden');
      // Update URL without reload
      const url = new URL(window.location);
      url.searchParams.set('tab', 'register');
      window.history.replaceState({}, '', url);
    }
  }

  // Run on initial load
  initAuthTabs();

  // Re-run after Astro page transitions
  document.addEventListener('astro:page-load', initAuthTabs);
</script>