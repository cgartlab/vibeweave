---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlaylistUploader from '../components/playlist/PlaylistUploader';
import PlaylistCard from '../components/playlist/PlaylistCard';
---

<BaseLayout title="我的歌单 - VibeWeave" description="管理你的歌单，开始情绪编织之旅">
  <div class="mx-auto max-w-5xl px-6 py-12">

    <!-- Page header -->
    <div class="mb-10 flex items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight text-white" style="letter-spacing: -0.025em;">
          我的歌单
        </h1>
        <p class="mt-1 text-sm" style="color: rgba(255,255,255,0.35);">
          管理和分析你的音乐收藏
        </p>
      </div>

      <button
        id="open-uploader-btn"
        class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold text-black transition-all duration-200 hover:bg-white/90 active:scale-95"
        style="background: #fff;"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        导入歌单
      </button>
    </div>

    <!-- Uploader panel (hidden by default) -->
    <div id="playlist-uploader-wrapper" class="mb-8 hidden">
      <div class="rounded-2xl border p-6 transition-all"
           style="background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08);">
        <PlaylistUploader client:visible />
      </div>
    </div>

    <!-- Grid or empty state -->
    <div id="playlist-grid">

      <!-- Empty state -->
      <div id="playlist-empty-state"
           class="flex flex-col items-center justify-center rounded-3xl border py-28 text-center"
           style="border-color: rgba(255,255,255,0.06); border-style: dashed;">
        <!-- Icon -->
        <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-2xl"
             style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);">
          <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2"
               style="color: rgba(255,255,255,0.15);">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
          </svg>
        </div>
        <p class="text-base font-medium" style="color: rgba(255,255,255,0.3);">还没有歌单</p>
        <p class="mt-1 text-sm" style="color: rgba(255,255,255,0.18);">
          导入你的第一个歌单，开始情绪分析之旅
        </p>
        <button
          id="empty-state-btn"
          class="mt-7 inline-flex items-center gap-2 rounded-full px-6 py-2.5 text-sm font-semibold text-white transition-all duration-200 hover:scale-[1.03]"
          style="background: linear-gradient(135deg, var(--color-vw-accent), #3b82f6);
                 box-shadow: 0 4px 16px rgba(139,92,246,0.3);"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          导入第一个歌单
        </button>
      </div>

      <!-- Cards grid (populated by JS) -->
      <div id="playlist-cards-grid"
           class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4 hidden">
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  // Auth guard
  async function checkAuth() {
    try {
      const { supabase } = await import('../lib/supabase/client');
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) window.location.href = import.meta.env.BASE_URL + 'login';
    } catch {
      console.warn('Auth check skipped: Supabase not available');
    }
  }
  checkAuth();
</script>

<script>
  // Toggle uploader
  const openBtn       = document.getElementById('open-uploader-btn') as HTMLButtonElement | null;
  const emptyBtn      = document.getElementById('empty-state-btn')   as HTMLButtonElement | null;
  const uploaderWrap  = document.getElementById('playlist-uploader-wrapper');

  function toggleUploader(force?: boolean) {
    if (!openBtn || !uploaderWrap) return;
    const show = force ?? uploaderWrap.classList.contains('hidden');
    uploaderWrap.classList.toggle('hidden', !show);
    openBtn.innerHTML = show
      ? `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
           <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
         </svg>关闭`
      : `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
           <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
         </svg>导入歌单`;
  }

  openBtn?.addEventListener('click', () => toggleUploader());
  emptyBtn?.addEventListener('click', () => toggleUploader(true));

  // Load playlists
  async function loadPlaylists() {
    try {
      const { supabase } = await import('../lib/supabase/client');
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) return;
      const { data: playlists } = await supabase
        .from('playlists')
        .select('*')
        .eq('user_id', session.user.id)
        .order('updated_at', { ascending: false });

      if (!playlists?.length) {
        document.getElementById('playlist-empty-state')?.classList.remove('hidden');
        document.getElementById('playlist-cards-grid')?.classList.add('hidden');
        return;
      }
      document.getElementById('playlist-empty-state')?.classList.add('hidden');
      const grid = document.getElementById('playlist-cards-grid');
      if (grid) {
        grid.classList.remove('hidden');
        const { createElement: h } = await import('react');
        const { createRoot } = await import('react-dom/client');
        const { default: PlaylistCard } = await import('../components/playlist/PlaylistCard');
        grid.innerHTML = '';
        playlists.forEach((pl) => {
          const el = document.createElement('div');
          grid.appendChild(el);
          createRoot(el).render(h(PlaylistCard, { id: pl.id, name: pl.name, songCount: pl.song_count, status: pl.status || 'draft' }));
        });
      }
    } catch (err) {
      console.warn('Failed to load playlists:', err);
    }
  }
  loadPlaylists();
</script>
