---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlaylistUploader from '../components/playlist/PlaylistUploader';
import PlaylistCard from '../components/playlist/PlaylistCard';
---

<BaseLayout title="我的歌单 - VibeWeave" description="管理你的歌单，开始情绪编织之旅">
  <main class="min-h-[calc(100vh-3rem)] mx-auto max-w-5xl px-6 py-12">
    <!-- Header -->
    <div class="mb-10 flex items-center justify-between">
      <div>
        <h1 class="font-body text-3xl font-semibold tracking-tight text-white">我的歌单</h1>
        <p class="mt-1 text-[15px] text-white/40">管理和分析你的音乐收藏</p>
      </div>
      <button
        id="open-uploader-btn"
        class="rounded-full bg-white text-black px-5 py-2.5 text-sm font-medium hover:bg-white/90 transition-all duration-300"
      >
        <svg class="h-4 w-4 inline-block mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        导入歌单
      </button>
    </div>

    <!-- Playlist Uploader -->
    <div id="playlist-uploader-wrapper" class="mb-8 hidden">
      <div class="rounded-2xl bg-white/[0.04] border border-white/[0.06] p-6">
        <PlaylistUploader client:visible />
      </div>
    </div>

    <!-- Playlist Grid -->
    <div id="playlist-grid">
      <!-- Empty state when no playlists -->
      <div id="playlist-empty-state" class="flex flex-col items-center justify-center py-24">
        <svg class="h-16 w-16 text-white/10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
        </svg>
        <p class="text-lg font-medium text-white/40 mt-4">还没有歌单</p>
        <p class="mt-1 text-sm text-white/20">导入你的第一个歌单，开始情绪分析之旅</p>
      </div>

      <!-- Playlist cards grid (populated by client-side script or React components) -->
      <div id="playlist-cards-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 hidden"></div>
    </div>
  </main>
</BaseLayout>

<script>
  // Simple auth check - redirect to /login if not authenticated
  async function checkAuth() {
    try {
      const { supabase } = await import('../lib/supabase/client');
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = import.meta.env.BASE_URL + 'login';
      }
    } catch {
      // If supabase is not configured, allow access for development
      console.warn('Auth check skipped: Supabase not available');
    }
  }

  checkAuth();
</script>

<script>
  // Toggle uploader visibility
  const openBtn = document.getElementById('open-uploader-btn');
  const uploaderWrapper = document.getElementById('playlist-uploader-wrapper');

  if (openBtn && uploaderWrapper) {
    openBtn.addEventListener('click', () => {
      const isHidden = uploaderWrapper.classList.contains('hidden');
      if (isHidden) {
        uploaderWrapper.classList.remove('hidden');
        openBtn.innerHTML = `
          <svg class="h-4 w-4 inline-block mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
          关闭
        `;
      } else {
        uploaderWrapper.classList.add('hidden');
        openBtn.innerHTML = `
          <svg class="h-4 w-4 inline-block mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          导入歌单
        `;
      }
    });
  }

  // Fetch and render user's playlists
  async function loadPlaylists() {
    try {
      const { supabase } = await import('../lib/supabase/client');
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) return;

      const { data: playlists, error } = await supabase
        .from('playlists')
        .select('*')
        .eq('user_id', session.user.id)
        .order('updated_at', { ascending: false });

      if (error || !playlists || playlists.length === 0) {
        document.getElementById('playlist-empty-state')?.classList.remove('hidden');
        document.getElementById('playlist-cards-grid')?.classList.add('hidden');
        return;
      }

      document.getElementById('playlist-empty-state')?.classList.add('hidden');
      const grid = document.getElementById('playlist-cards-grid');
      if (grid) {
        grid.classList.remove('hidden');
        const { createElement: h } = await import('react');
        const { createRoot } = await import('react-dom/client');
        const PlaylistCardModule = await import('../components/playlist/PlaylistCard');

        grid.innerHTML = '';
        playlists.forEach((playlist) => {
          const cardContainer = document.createElement('div');
          grid.appendChild(cardContainer);
          const root = createRoot(cardContainer);
          root.render(
            h(PlaylistCardModule.default, {
              id: playlist.id,
              name: playlist.name,
              songCount: playlist.song_count,
              status: playlist.status || 'draft',
            })
          );
        });
      }
    } catch (err) {
      console.warn('Failed to load playlists:', err);
      document.getElementById('playlist-empty-state')?.classList.remove('hidden');
      document.getElementById('playlist-cards-grid')?.classList.add('hidden');
    }
  }

  loadPlaylists();
</script>